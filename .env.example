# Optional: copy to `.env.local` to override defaults.
# `npm run dev` loads `.env.development` — live API + empty base URL uses the Vite proxy:
# `/v1` → http://127.0.0.1:8000 (see vite.config.ts).

# Production builds: set one of these (dev defaults to live API without any file).
# VITE_USE_LIVE_API=true

# Use demo registration/login with no backend (overrides dev default).
# VITE_USE_MOCK_API=true

# Option A: same-origin via dev proxy — leave empty
# VITE_API_BASE_URL=

# Option B: call backend directly (ensure CORS allows the dev origin).
# Use the server origin only — do not append /v1 (paths already include /v1/...).
# VITE_API_BASE_URL=http://localhost:8000

# Backend must use the same public URL for verification links in emails:
# PUBLIC_APP_URL=http://localhost:5173  (in afri-trust-backend/.env)
